# Browser settings
BROWSER_HEADED=true
BROWSER_BLOCK_MEDIA=false
HUMAN_DELAY_MIN=50
HUMAN_DELAY_MAX=200

# CDP Connect mode (RECOMMENDED) — attach to your already-running Chrome.
# Start Chrome with: --remote-debugging-port=9222
# This uses your real browser with all logins, cookies, and sessions.
BROWSER_CDP_URL=http://localhost:9222

# Persistent Launch mode (fallback if BROWSER_CDP_URL is not set)
# Spawns a NEW Chrome window with this profile directory.
# CHROME_USER_DATA_DIR=C:\Users\georg\AppData\Local\mcp-unified-automation\chrome-profile

# Performance
FAST_MODE=true

# API Orchestrator (npm run api)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ORCHESTRATOR_MAX_TURNS=50
